#!/bin/bash

# Ermittelt aus einem Epic die referenzierten User Stories und prüft,
# für welche im Backlog noch KEIN Ticket existiert.
# Verhindert doppelte Ticketnummern, indem bereits vorhandene Tickets
# (anhand der CLVN-Nummer, unabhängig vom Dateinamen) erkannt und
# als "vorhanden" markiert werden.
#
# Usage: ./scripts/list-missing-stories <pfad-zum-epic.md>

set -euo pipefail

EPIC_FILE="${1:-}"
BACKLOG_DIR="docs/product/backlog"

if [ -z "$EPIC_FILE" ] || [ ! -f "$EPIC_FILE" ]; then
  echo "Fehler: Epic-Datei nicht gefunden: '$EPIC_FILE'" >&2
  echo "Usage: $0 <pfad-zum-epic.md>" >&2
  exit 1
fi

echo "Epic:    $(basename "$EPIC_FILE")"
echo "Backlog: $BACKLOG_DIR"
echo
echo "Referenzierte User Stories:"

# Extrahiere alle im Epic referenzierten User-Story-Dateinamen
STORIES=$(grep -oE 'CLVN-[0-9]+-STORY-[a-z0-9-]+\.md' "$EPIC_FILE" | sort -u || true)

if [ -z "$STORIES" ]; then
  echo "  (keine User-Story-Referenzen im Epic gefunden)" >&2
  exit 0
fi

echo "$STORIES" | while read -r FILENAME; do
  TICKET=$(echo "$FILENAME" | grep -oE 'CLVN-[0-9]+')
  # Prüfe, ob bereits ein Ticket mit dieser Nummer im Backlog liegt
  EXISTING=$(find "$BACKLOG_DIR" -name "${TICKET}-*.md" 2>/dev/null | head -1 || true)
  if [ -n "$EXISTING" ]; then
    printf "  [vorhanden] %s -> %s  (ueberspringen)\n" "$TICKET" "$(basename "$EXISTING")"
  else
    printf "  [fehlt]     %s -> %s  (Ticket erstellen)\n" "$TICKET" "$FILENAME"
  fi
done
